
---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import BackBtn from "@/components/BackBtn.astro";
import BackToTop from "../../components/BackToTop.astro";
import formatDatetime from "@/lib/formatDatetime";

export async function getStaticPaths() {
    const posts = await getCollection('projects');
    return posts.map(post => ({
        params: { id: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { title, summary, tags, cover, ogImage, url, startDate, endDate } = post.data;
const start = startDate ? formatDatetime(startDate) : undefined;
const end = endDate ? formatDatetime(endDate) : (startDate ? 'Présent' : undefined);
const projectLinkLabel = url?.includes('github.com') ? 'Lien GitHub ↗' : 'Lien du projet ↗';

const { Content } = await render(post);

---
<Layout title={title} description={summary} imageOg={ogImage} scrollSmooth={true}>
    <>
        <div class="flex justify-center mt-10">
            <BackBtn/>
        </div>
        <div class="flex flex-col gap-6 justify-center items-center">
            <h1 class="text-3xl font-bold text-center">{title}</h1>
            <p class="text-sm text-n500 dark:text-primary-light ">
                {tags.join(', ')}
            </p>
                        {start && (
                            <p class="text-xs text-n400 dark:text-light-theme">
                                {end ? `${start} – ${end}` : start}
                            </p>
                        )}
        </div>
        <Image transition:name={`${post.id}-image`} class="rounded-2xl" src={cover} alt="Main project image"/>
        <p>
            {summary}
        </p>

        <article id="article" class="mt-8 prose dark:prose-invert">
            <Content/>
        </article>

        {url && (
            <a href={url} rel="noreferrer" target="_blank">
                {projectLinkLabel}
            </a>
        )}

        <div
            id="project-image-lightbox"
            class="hidden fixed inset-0 z-50 items-center justify-center bg-black/90 p-4 md:p-10"
            role="dialog"
            aria-modal="true"
            aria-label="Agrandissement de l'image"
        >
            <button
                id="project-image-lightbox-close"
                type="button"
                class="absolute top-4 right-4 text-white text-3xl leading-none w-10 h-10 rounded-full bg-white/10 hover:bg-white/20"
                aria-label="Fermer l'image agrandie"
            >
                ×
            </button>

            <img
                id="project-image-lightbox-img"
                class="max-h-full max-w-full object-contain rounded-xl"
                alt=""
            />
        </div>

        <script>
            const initProjectImageLightbox = () => {
                const article = document.getElementById("article");
                const lightbox = document.getElementById("project-image-lightbox");
                const lightboxImage = document.getElementById("project-image-lightbox-img");
                const lightboxClose = document.getElementById("project-image-lightbox-close");

                if (!article || !lightbox || !lightboxImage || !lightboxClose) {
                    return;
                }

                const setupCaptureGrids = (articleElement: HTMLElement) => {
                    if (articleElement.dataset.captureGridReady === "true") {
                        return;
                    }

                    const captureHeadings = Array.from(articleElement.querySelectorAll<HTMLHeadingElement>("h2, h3"))
                        .filter((heading) => {
                            const headingText = heading.textContent?.trim().toLowerCase() || "";
                            return headingText === "captures" || headingText === "captures du projet";
                        });

                    captureHeadings.forEach((heading) => {
                        if (heading.nextElementSibling?.classList.contains("project-captures-grid")) {
                            return;
                        }

                        const grid = document.createElement("div");
                        grid.className = "project-captures-grid";

                        let sibling = heading.nextElementSibling;
                        while (sibling) {
                            if (/^H[1-6]$/.test(sibling.tagName)) {
                                break;
                            }

                            const nextSibling = sibling.nextElementSibling;
                            const directImage = sibling.tagName === "P"
                                ? sibling.querySelector<HTMLImageElement>(":scope > img")
                                : null;

                            if (directImage && sibling.children.length === 1) {
                                sibling.classList.add("project-capture-item");
                                grid.appendChild(sibling);
                            }

                            sibling = nextSibling;
                        }

                        if (grid.children.length > 0) {
                            heading.insertAdjacentElement("afterend", grid);
                        }
                    });

                    articleElement.dataset.captureGridReady = "true";
                };

                setupCaptureGrids(article);

                if (article.dataset.lightboxReady === "true") {
                    return;
                }

                article.dataset.lightboxReady = "true";

                const openLightbox = (image: HTMLImageElement) => {
                    const source = image.currentSrc || image.getAttribute("src");

                    if (!source) {
                        return;
                    }

                    lightboxImage.setAttribute("src", source);
                    lightboxImage.setAttribute("alt", image.getAttribute("alt") || "Image agrandie");
                    lightbox.classList.remove("hidden");
                    lightbox.classList.add("flex");
                    document.body.style.overflow = "hidden";
                };

                const closeLightbox = () => {
                    lightbox.classList.add("hidden");
                    lightbox.classList.remove("flex");
                    lightboxImage.removeAttribute("src");
                    document.body.style.overflow = "";
                };

                article.querySelectorAll<HTMLImageElement>("img").forEach((image) => {
                    if (image.closest("a")) {
                        return;
                    }

                    image.classList.add("cursor-zoom-in");
                    image.addEventListener("click", () => openLightbox(image));
                });

                lightboxClose.addEventListener("click", closeLightbox);
                lightbox.addEventListener("click", (event) => {
                    if (event.target === lightbox) {
                        closeLightbox();
                    }
                });
            };

            initProjectImageLightbox();
            document.addEventListener("astro:page-load", initProjectImageLightbox);
        </script>
        <BackToTop />
    </>
</Layout>

<style is:global>
    h2 {
        @apply text-2xl font-bold my-4;
    }

    #article .project-captures-grid {
        @apply grid grid-cols-1 md:grid-cols-2 gap-4 my-6;
    }

    #article .project-captures-grid .project-capture-item {
        @apply m-0;
    }

    #article .project-captures-grid .project-capture-item img {
        @apply w-full h-auto;
    }
</style>

