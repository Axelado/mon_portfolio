---
// astro imports
import {getCollection} from "astro:content";

// components imports
import ProjectCard from "./ProjectCard.astro";
import {buttonVariants} from "./ui/button";
import {withBase} from "../lib/utils";

const pinnedSlugs = [
    'integration-hc10-kinect',
    'robot-scara',
    'pge-upcithy-twinswheel',
    'yellolab-robot-ros2',
    'robot-mapping-2d',
];

const projects = (await getCollection('projects', ({ data }) => data.listed !== false))
    .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());

const pinned = pinnedSlugs
    .map(slug => projects.find(p => p.id === slug))
    .filter(Boolean);
const rest = projects.filter(p => !pinnedSlugs.includes(p.id));
const allProjects = [...pinned, ...rest];
---

<!--Grid section to show the projects in to columns -->
<>
    <section class="mt-10 px-4 w-full">
        <div class="mb-4">
            <h2 class="text-3xl font-bold mb-4">Projects</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {
                allProjects.map((project) => (
                        <ProjectCard
                                id={project.id}
                                title={project.data.title}
                                summary={project.data.summary}
                                tags={project.data.tags}
                                cover={project.data.cover}
                            startDate={project.data.startDate}
                            endDate={project.data.endDate}
                        />
                ))
            }
        </div>
    </section>
    <div class="flex justify-center mt-10">
        <a href={withBase('/projects')} class={buttonVariants({ variant: "default" }) + "text-n700 bg-primary-light dark:bg-primary-dark hover:bg-primary-hover-light dark:hover:bg-primary-hover-dark"}>
            See All Projects
        </a>
    </div>
</>



